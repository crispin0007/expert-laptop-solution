# ─── Copy this to .env and fill in every value ───────────────────────────────
# Never commit .env to version control.

# ─── Django ──────────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_SETTINGS_MODULE=config.settings.prod

# Comma-separated: root domain + wildcard
ALLOWED_HOSTS=bms.techyatra.com.np,*.bms.techyatra.com.np
# Root domain used for subdomain resolution and Caddy TLS cert verification
ROOT_DOMAIN=bms.techyatra.com.np
# Email for Let's Encrypt certificate registration (used by Caddy)
ADMIN_EMAIL=your@email.com
# Root domain used for subdomain resolution and Caddy cert verification
ROOT_DOMAIN=bms.techyatra.com.np

# ─── Database (PostgreSQL 16) ─────────────────────────────────────────────────
POSTGRES_DB=nexusbms
POSTGRES_USER=nexusadmin
POSTGRES_PASSWORD=change-me-strong-db-password
# POSTGRES_HOST and POSTGRES_PORT are set inside docker-compose (db / 5432)

# ─── Cache / Queue (Redis 7) ──────────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong-redis-password
# REDIS_URL is constructed inside docker-compose using REDIS_PASSWORD:
#   redis://:${REDIS_PASSWORD}@redis:6379/0

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-address@gmail.com
# Use a Gmail App Password (not your login password)
# Create one at: https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=NEXUS BMS <your-address@gmail.com>

# ─── Firebase (FCM push notifications) ───────────────────────────────────────
# Download the JSON from Firebase Console → Project Settings → Service Accounts
# Place it at the path below (mounted into the container via docker-compose volume)
FIREBASE_CREDENTIALS_PATH=/usr/src/app/firebase-credentials.json

# ─── Frontend (Vite build args — passed at docker build time) ─────────────────
VITE_API_BASE=https://bms.techyatra.com.np
VITE_ROOT_DOMAIN=bms.techyatra.com.np
