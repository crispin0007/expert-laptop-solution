# === Database ===
POSTGRES_DB=techyatra
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# === Django ===
DJANGO_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
ALLOWED_HOSTS=

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Frontend ===
VITE_ROOT_DOMAIN=bms.techyatra.com.np
VITE_API_BASE=

# === SMTP (Gmail App Password recommended) ===
# 1. Enable 2FA on the Gmail account
# 2. Go to myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
# 4. Paste the 16-char password below (no spaces)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your16charapppassword
DEFAULT_FROM_EMAIL=TechYatra <your@gmail.com>
