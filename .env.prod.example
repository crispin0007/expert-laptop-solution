# === Database ===
POSTGRES_DB=techyatra
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# === Django ===
DJANGO_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
# ALLOWED_HOSTS is now auto-configured in prod.py for .bms.techyatra.com.np
# Only set this if you need to add extra hosts
ALLOWED_HOSTS=

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Frontend ===
# Root admin domain — tenants open at <slug>.bms.techyatra.com.np
VITE_ROOT_DOMAIN=bms.techyatra.com.np
# API base URL — leave empty, frontend uses relative /api/v1/ via Nginx
VITE_API_BASE=
