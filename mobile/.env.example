# ── API ──────────────────────────────────────────────────────────────────────
API_BASE_URL=https://bms.techyatra.com.np/api/v1
ROOT_DOMAIN=bms.techyatra.com.np

# ── Build ─────────────────────────────────────────────────────────────────────
APP_ENV=development
EAS_PROJECT_ID=

# ── Firebase (for push notifications) ────────────────────────────────────────
# Place GoogleService-Info.plist and google-services.json in ./google-services/
GOOGLE_SERVICES_PLIST=./google-services/GoogleService-Info.plist
GOOGLE_SERVICES_JSON=./google-services/google-services.json
